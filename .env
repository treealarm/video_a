# video_a is a standalone, dependency-light analytics engine — these are its own conventions,
# independent of vms_rec's .env (no APP_ID/PUBSUB_NAME/DAPR_CFG_APP_ID etc. needed: video_a never
# calls anyone itself, it only accepts calls).

ANALYTICS_GRPC_PORT=50060
ANALYTICS_MODEL_PATH=/models
ANALYTICS_DEVICE=CPU

# Optional, dev/test-only: when models are absent (Phase 1 stub inference), periodically emit one
# synthetic PERSON detection so the whole pipeline (StreamDetections -> VmsAnalytics ->
# RetainEvent -> ListDetections) is exercisable end-to-end without real models. Must stay unset
# ("false"/absent) once real models are wired in.
ANALYTICS_STUB_SYNTHETIC_DETECTIONS=false
